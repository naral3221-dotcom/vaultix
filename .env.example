# Project
COMPOSE_PROJECT_NAME=vaultix
TZ=Asia/Seoul
VAULTIX_ENV=development
VAULTIX_VERSION=0.1.0

# Public endpoints
PUBLIC_SITE_URL=https://vaultix.example.com
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8302
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# App ports
VAULTIX_WEB_PORT=8301
VAULTIX_API_PORT=8302
VAULTIX_PLAUSIBLE_PORT=8303
VAULTIX_LISTMONK_PORT=8304
VAULTIX_UPTIME_KUMA_PORT=8305
VAULTIX_POSTGRES_PORT=5440
VAULTIX_REDIS_PORT=6380

# Database
POSTGRES_DB=vaultix
POSTGRES_USER=vaultix
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://vaultix:change-me@postgres:5432/vaultix

# Redis / workers
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth / email
AUTH_SECRET=change-me
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
RESEND_API_KEY=
MAIL_FROM=Vaultix <no-reply@vaultix.example.com>
TURNSTILE_SECRET_KEY=
ADMIN_EMAILS=

# External LLM providers; Ollama, Replicate, and fal.ai are intentionally absent.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
ZAI_API_KEY=

# Image routing
NANOBANANA_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
COMFYUI_BASE_URL=

# Observability
SENTRY_DSN_API=
SENTRY_DSN_WEB=
PLAUSIBLE_SECRET_KEY_BASE=change-me
PLAUSIBLE_TOTP_VAULT_KEY=change-me
UPTIME_KUMA_ADMIN_EMAIL=
UPTIME_KUMA_ADMIN_PASSWORD=

# Newsletter
LISTMONK_ADMIN_USER=vaultix
LISTMONK_ADMIN_PASSWORD=change-me
